.sousuo {
  display: flex;
  align-content: center;
  align-items: center;
  background-color: #E5E5E5;
  padding: 5px 0;
  margin-left: 5%;
  margin-top: 10px;
  margin-bottom: 10px;
  border-radius: 5px;
}
.sousuo .sousuo_ico {
  width: 10%;
  text-align: center;
}
.sousuo .sousuo_input {
  width: 90%;
}
.sousuo .sousuo_input input {
  font-size: 10px;
  letter-spacing: 1px;
}
.sousuo .sousuo_input .sousuo_placeholder {
  font-size: 10px;
  color: #7E7E7E;
}
.sousuo .sousuo_cances {
  position: absolute;
  width: 93%;
  text-align: right;
  font-size: 15px;
  color: #666;
}
.banner swiper {
  width: 750rpx;
  height: 380rpx;
}
.banner swiper image {
  height: 100%;
  width: 100%;
}
.hot_list {
  background: #eee;
  overflow: hidden;
}
.tit {
  height: 50px;
  line-height: 50px;
  color: #000;
  text-align: center;
  letter-spacing: 20rpx;
  background: #fff;
  margin: 10rpx 0;
}

